__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Environments ──────────────────────────────────────────────────────────────
.env
.envrc
.venv
env/
venv/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

